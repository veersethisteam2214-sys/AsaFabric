# Secrets — never commit
.env
*service-account*.json
*.credentials.json

# Raw page photos + scans — never commit (they live in Google Drive)
photos/*
!photos/.gitkeep
drive_upload/
data/pdf_tmp/
tmp/
google-sheets-tracking/photos/*
!google-sheets-tracking/photos/.gitkeep
google-sheets-tracking/drive_upload/
google-sheets-tracking/data/pdf_tmp/
google-sheets-tracking/tmp/

# Generated data
data/raw/*
!data/raw/.gitkeep
data/*.csv
google-sheets-tracking/data/raw/*
!google-sheets-tracking/data/raw/.gitkeep
google-sheets-tracking/data/*.csv

# Python
.venv/
venv/
__pycache__/
*.pyc

# macOS
.DS_Store
