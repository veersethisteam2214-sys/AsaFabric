# Secrets — never commit
.env
*service-account*.json
*.credentials.json

# Raw page photos + scans — never commit (they live in Google Drive)
photos/*
!photos/.gitkeep
drive_upload/
data/pdf_tmp/

# Generated data
data/raw/*
!data/raw/.gitkeep
data/*.csv

# Python
.venv/
venv/
__pycache__/
*.pyc

# macOS
.DS_Store
