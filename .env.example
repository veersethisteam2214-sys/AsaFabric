# --- Which two models to cross-check (provider:model_id) -------------------
# The Phase 0 pilot decides these. Confirm exact model ids in each provider's
# docs the day you run — identifiers drift monthly (see README "Open risks").
MODEL_A=gemini:gemini-3.5-flash
MODEL_B=anthropic:claude-sonnet-4-6

# --- API keys (only fill in the two providers you actually use) ------------
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# --- Google Sheets ---------------------------------------------------------
# Create a service account, download its JSON key, and SHARE the target Sheet
# with the service-account email (…@….iam.gserviceaccount.com).
GOOGLE_SHEET_ID=
GOOGLE_WORKSHEET=inventory
GOOGLE_SA_JSON=service-account.json

# --- Optional tuning -------------------------------------------------------
DEDUPE_AUTO_MERGE=90
DEDUPE_REVIEW_FLOOR=60
YARDAGE_MIN=0
YARDAGE_MAX=100000
